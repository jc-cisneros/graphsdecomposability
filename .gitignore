# Module input/ and output/ are regenerated by each make.sh run.
# Track only the analysis outputs the paper depends on.
1_data/input/
2_analysis/input/
3_slides/input/
3_slides/output/
4_paper/input/
4_paper/output/

# 2_analysis/output: ignore most derivatives, but track the LaTeX tables
# and the small set of paper-input figures so the writeup can be rebuilt
# without rerunning the simulation grid.
2_analysis/output/scalars/
2_analysis/output/*.log
2_analysis/output/*.rds
2_analysis/output/tables/*.csv
2_analysis/output/tables/*.xlsx
2_analysis/output/figures/*
!2_analysis/output/figures/lambda_sensitivity.pdf
!2_analysis/output/figures/ddly_network_*.pdf

# Local environment
.envrc
.micromamba/
.conda_pkgs/
.conda_info
.conda-lock.input.sha256
.setup_logs/
externals/

# LaTeX intermediate files
*.aux
*.bbl
*.blg
*.bcf
*.run.xml
*.out
*.fdb_latexmk
*.fls
*.synctex.gz
*.nav
*.snm
*.toc
*.lof
*.lot
**/source/*.log
**/source/*.pdf

# R intermediate files
*.Rhistory
*.Rapp.history
Rplots.pdf

# Editor / OS noise
*.DS_Store
*.Zone.Identifier
*.ipynb_checkpoints/
